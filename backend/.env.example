# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}
FRONTEND_URL=http://localhost:3000

# Session
SESSION_DRIVER=cookie

# Redis (for BullMQ queue - AI worker communication)
REDIS_HOST=localhost
REDIS_PORT=6379

# Cloudflare R2 (S3-compatible object storage)
# Get credentials: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

#--------------------------------------------------------------------
# Social OAuth (YouTube, TikTok, Instagram/Facebook)
#--------------------------------------------------------------------
# FRONTEND_URL=http://localhost:3000
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

#--------------------------------------------------------------------
# Email (SMTP) — transactional mail & mandatory verification when set
#--------------------------------------------------------------------
# When SMTP_HOST, SMTP_USER, and SMTP_PASSWORD are set, new email/password
# signups receive a verification link and cannot sign in until verified.
# Leave SMTP empty in local dev to auto-verify new accounts (no email sent).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# MAIL_FROM_ADDRESS=noreply@yourdomain.com
# MAIL_FROM_NAME=Cutnary
# Set to false only if you must disable mandatory verification while SMTP is configured (not recommended).
# REQUIRE_EMAIL_VERIFICATION=true

#--------------------------------------------------------------------
# Google Sign-In (OAuth 2.0) — separate from GOOGLE_API_KEY (Gemini)
#--------------------------------------------------------------------
# Create OAuth 2.0 Client (Web) in Google Cloud Console. Authorized redirect URI must match:
#   ${APP_URL}/api/auth/google/callback
# Example: http://localhost:3333/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional override if the default APP_URL-based callback is wrong behind a proxy:
# GOOGLE_REDIRECT_URI=

#--------------------------------------------------------------------
# Google AI (Gemini) — hashtags / AI features (not login)
#--------------------------------------------------------------------
# GOOGLE_API_KEY=